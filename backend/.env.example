# Server
PORT=8787

# JWT (required for auth tokens)
JWT_SECRET=change-me-in-production

# QQ 邮箱 SMTP（3067938917@qq.com）
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP
# 2. 生成「授权码」（不是 QQ 登录密码）
# 3. 把授权码填到 SMTP_PASS
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=3067938917@qq.com
SMTP_PASS=your-qq-mail-authorization-code
SMTP_FROM="轻鹭 BurnPal <3067938917@qq.com>"

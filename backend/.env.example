# Server
PORT=8787

# JWT (required for auth tokens)
JWT_SECRET=change-me-in-production

# Vercel → Render: shared secret when RESEND_API_KEY lives only on Vercel
QINGLU_PROXY_SECRET=

# --- Email (pick ONE provider) ---

# Recommended on Render FREE tier (SMTP ports 465/587 are blocked)
# 1. Sign up at https://resend.com
# 2. Create API key → paste below
# 3. Verify your domain in Resend, then set RESEND_FROM to e.g. QingLu <noreply@yourdomain.com>
#    For quick tests only: QingLu <onboarding@resend.dev> (Resend may limit recipients)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=QingLu <onboarding@resend.dev>

# QQ Mail SMTP (works locally; Render free tier CANNOT reach SMTP — upgrade or use Resend)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=yourname@qq.com
SMTP_PASS=your-qq-mail-authorization-code
SMTP_FROM=QingLu <yourname@qq.com>

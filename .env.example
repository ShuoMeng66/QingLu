# QingLu deployment environment (Vercel + Render)
# Copy relevant sections to your hosting provider dashboards.
# Do NOT commit real secrets.

# --- Vercel (project root) ---
OPENCLAW_TOKEN=
OPENCLAW_PROXY_TARGET=https://dashscope.aliyuncs.com
OPENCLAW_PROXY_PATH=/compatible-mode
VITE_OPENCLAW_BASE_URL=/api/openclaw/v1
VITE_OPENCLAW_AGENT=deepseek-v4-flash
BACKEND_URL=
QINGLU_PROXY_SECRET=
RESEND_API_KEY=
RESEND_FROM=QingLu <onboarding@resend.dev>

# --- Render (backend service, root: backend/) ---
JWT_SECRET=
# QINGLU_PROXY_SECRET= (same as Vercel)
# RESEND_API_KEY=
# RESEND_FROM=

# --- Local frontend (see frontend/.env.example) ---
# VITE_OPENCLAW_TOKEN=  # dev only; never in production builds
# VITE_API_BASE_URL=http://localhost:3001

# --- Local backend (see backend/.env.example) ---
# PORT=3001
